        <div class="grid gap-6 mb-10" id="jobs-grid">

            <!-- ===== JOB 1: CARDIAC CATH TECH ===== -->
            <article class="job-card bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" data-category="healthcare" data-title="cardiac catheterization technician jackson michigan cath lab" itemscope itemtype="https://schema.org/JobPosting">
                <meta itemprop="datePosted" content="2026-03-19">
                <meta itemprop="employmentType" content="CONTRACTOR">
                <div class="flex flex-col md:flex-row">
                    <!-- Left accent bar -->
                    <div class="w-full md:w-2 flex-shrink-0 healthcare-badge md:rounded-l-xl"></div>
                    <div class="p-6 flex-1">
                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                            <div class="flex-1">
                                <!-- Header row -->
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="text-xs px-2 py-1 rounded-full text-white font-semibold healthcare-badge">Healthcare</span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700 font-semibold">● Open</span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700 font-semibold">Contract</span>
                                    <span class="text-xs text-gray-400">Posted Mar 19, 2026</span>
                                </div>
                                <h2 class="text-xl font-bold text-gray-900 mb-1" itemprop="title">Cardiac Catheterization Technician</h2>
                                <div class="flex flex-wrap gap-4 text-sm text-gray-600 mb-3">
                                    <span class="flex items-center gap-1">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                        <span itemprop="hiringOrganization" itemscope itemtype="https://schema.org/Organization"><span itemprop="name">Henry Ford Jackson Hospital</span></span>
                                    </span>
                                    <span class="flex items-center gap-1">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                                        <span itemprop="jobLocation">Jackson, MI 49201</span>
                                    </span>
                                    <span class="flex items-center gap-1">
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                        Day Shift 7am–5:30pm • 4 days/week • 40 hrs/week
                                    </span>
                                </div>

                                <!-- Summary -->
                                <p class="text-gray-700 text-sm mb-4" itemprop="description">
                                    Work directly alongside cardiologists in a fully equipped cath lab performing diagnostic and interventional cardiac procedures. You'll manage complex cardiovascular cases including coronary stenting, PTCA, atherectomy, and peripheral angioplasty while maintaining sterile fields and operating specialized imaging systems.
                                </p>

                                <!-- Key Requirements -->
                                <div class="mb-4">
                                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Key Requirements</p>
                                    <ul class="text-sm text-gray-700 space-y-1">
                                        <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>1–2 years recent Cath Lab experience required</li>
                                        <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>2 years full-time Invasive Cardiovascular Technology experience</li>
                                        <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>On-call participation required; must be available for late cases</li>
                                        <li class="flex items-start gap-2"><svg class="w-4 h-4 text-yellow-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>Electrophysiology experience preferred</li>
                                    </ul>
                                </div>

                                <!-- Certs & Education -->
                                <div class="flex flex-wrap gap-1 mb-2">
                                    <span class="tag-pill cert-tag">BLS Required</span>
                                    <span class="tag-pill cert-tag">ACLS Required</span>
                                    <span class="tag-pill skill-tag">Cath Lab</span>
                                    <span class="tag-pill skill-tag">Cardiac Intervention</span>
                                    <span class="tag-pill skill-tag">Sterile Technique</span>
                                    <span class="tag-pill" style="background:#fef3c7;color:#92400e;">EP Preferred</span>
                                </div>
                                <p class="text-xs text-gray-500">Education: High School Diploma/GED required · Associate's or Bachelor's in health/science preferred · Graduate of accredited Invasive Cardiovascular Technology program preferred</p>
                            </div>

                            <!-- Apply CTA -->
                            <div class="flex-shrink-0 flex flex-col gap-3 md:items-end">
                                <a href="mailto:info@starworkforce.net?subject=Application: Cardiac Catheterization Technician - Jackson MI&body=Hello STAR Workforce Team,%0D%0A%0D%0AI am applying for the Cardiac Catheterization Technician position at Henry Ford Jackson Hospital in Jackson, MI.%0D%0A%0D%0APlease find my resume attached.%0D%0A%0D%0AName:%0D%0APhone:%0D%0AYears of Cath Lab Experience:%0D%0ACertifications (BLS/ACLS):%0D%0AAvailable Start Date:%0D%0A%0D%0AThank you."
                                   onclick="gtag('event', 'apply_click', {'job_title': 'Cardiac Catheterization Technician', 'category': 'healthcare'})"
                                   class="px-6 py-3 rounded-lg font-bold text-sm text-white text-center transition-all hover:opacity-90 active:scale-95"
                                   style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                                    Apply Now →
                                </a>
                                <p class="text-xs text-gray-400 text-center">Attach resume to email</p>
                            </div>
                        </div>
                    </div>
                </div>
            </article>

            <!-- ===== JOB 2: ICU RN ===== -->
            <article class="job-card bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden" data-category="healthcare" data-title="registered nurse icu intensive care unit utica new york travel rn night shift" itemscope itemtype="https://schema.org/JobPosting">
                <meta itemprop="datePosted" content="2026-03-19">
                <meta itemprop="employmentType" content="CONTRACTOR">
                <div class="flex flex-col md:flex-row">
                    <div class="w-full md:w-2 flex-shrink-0 healthcare-badge md:rounded-l-xl"></div>
                    <div class="p-6 flex-1">
                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                            <div class="flex-1">
                                <div class="flex flex-wrap items-center gap-2 mb-2">
                                    <span class="text-xs px-2 py-1 rounded-full text-white font-semibold healthcare-badge">Healthcare</span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-700 font-semibold">● Open</span>
                                    <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-700 font-semibold">Travel Contract</span>
                                    <span class="text-xs text-gray-400">Posted Mar 19, 2026</span>
                                </div>
                                <h2 class="text-xl font-bold text-gray-900 mb-1" itemprop="title">Registered Nurse – Intensive Care Unit (ICU)</h2>
