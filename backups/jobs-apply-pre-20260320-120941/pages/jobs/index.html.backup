    <script>
        // Mobile menu toggle
        document.getElementById('mobile-menu-btn').addEventListener('click', function() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        });

        // Filter jobs by category
        function filterJobs(category) {
            const jobs = document.querySelectorAll('[data-category]');
            const hcHeader = document.getElementById('healthcare-section-header');
            const itHeader = document.getElementById('it-section-header');
            const noResults = document.getElementById('no-results');

            // Update button states
            ['all','it','healthcare'].forEach(c => {
                const btn = document.getElementById('btn-' + c);
                btn.classList.remove('active');
            });
            document.getElementById('btn-' + category).classList.add('active');

            // Show/hide jobs
            let visible = 0;
            jobs.forEach(job => {
                const match = category === 'all' || job.dataset.category === category;
                job.style.display = match ? '' : 'none';
                if (match) visible++;
            });

            // Show/hide section headers
            hcHeader.style.display = (category === 'all' || category === 'healthcare') ? '' : 'none';
            itHeader.style.display = (category === 'all' || category === 'it') ? '' : 'none';
            noResults.classList.toggle('hidden', visible > 0);

            // Clear search
            document.getElementById('job-search').value = '';
        }

        // Search jobs
        function searchJobs() {
            const query = document.getElementById('job-search').value.toLowerCase().trim();
            const jobs = document.querySelectorAll('[data-category]');
            const hcHeader = document.getElementById('healthcare-section-header');
            const itHeader = document.getElementById('it-section-header');
            const noResults = document.getElementById('no-results');

            // Reset filter buttons
            ['all','it','healthcare'].forEach(c => document.getElementById('btn-' + c).classList.remove('active'));
            document.getElementById('btn-all').classList.add('active');

            let hcVisible = 0, itVisible = 0;

            jobs.forEach(job => {
                const searchText = job.dataset.title + ' ' + job.textContent.toLowerCase();
                const match = !query || searchText.includes(query);
                job.style.display = match ? '' : 'none';
                if (match && job.dataset.category === 'healthcare') hcVisible++;
                if (match && job.dataset.category === 'it') itVisible++;
            });

            hcHeader.style.display = hcVisible > 0 ? '' : 'none';
            itHeader.style.display = itVisible > 0 ? '' : 'none';
            noResults.classList.toggle('hidden', hcVisible + itVisible > 0);
        }
    </script>
</body>
